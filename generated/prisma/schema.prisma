generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      ERole    @default(System_Admin)
  password  String
  contactNo String
  photo     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isBlocked Boolean  @default(false)
}

enum ERole {
  Business_Admin
  System_Admin
}
